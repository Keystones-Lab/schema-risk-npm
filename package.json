{
  "name": "@schema-risk/cli",
  "version": "1.0.0",
  "description": "Production-grade PostgreSQL migration safety analyzer — detect dangerous schema changes before they reach production",
  "keywords": [
    "database",
    "migration",
    "sql",
    "postgresql",
    "risk",
    "cli",
    "schema",
    "drift",
    "sarif",
    "devops"
  ],
  "homepage": "https://github.com/Keystones-Lab/schema-risk-npm#readme",
  "bugs": {
    "url": "https://github.com/Keystones-Lab/schema-risk-npm/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Keystones-Lab/schema-risk-npm.git"
  },
  "license": "MIT",
  "author": "Keystones-Lab",
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "bin": {
    "schema-risk": "./dist/cli.mjs"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CONTRIBUTING.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/ __tests__/",
    "lint:fix": "eslint src/ __tests__/ --fix",
    "format": "prettier --write \"src/**/*.ts\" \"__tests__/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"__tests__/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "chalk": "^4.1.2",
    "commander": "^12.1.0",
    "yaml": "^2.6.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@typescript-eslint/eslint-plugin": "^8.16.0",
    "@typescript-eslint/parser": "^8.16.0",
    "eslint": "^8.57.0",
    "prettier": "^3.4.2",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
